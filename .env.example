# LLM Provider Configuration
# Configure your LLM provider(s) below

# OpenRouter API Key
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama Base URL (for local LLM)
# Ensure Ollama is running: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434

# MVP_USE_MOCK_LLM=true
# Set to "true" to use mock LLM adapter (deterministic routing, no real AI provider needed).
# Useful for local development / testing without configuring external LLM providers.
# Do NOT set in production.

# Application Security
# APP_SECRET_KEY - used to encrypt provider API keys at rest (generate with: openssl rand -hex 32)
APP_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
DATABASE_PATH=./data/app.db

# Port Configuration (uncomment to override defaults)
# PORT=3003
# HOST=localhost  # Set to 0.0.0.0 for production public ingress
# VITE_PORT=3002
# VITE_API_TARGET=http://localhost:3003

# Resource Limits (optional - uses defaults if not set)
# MAX_CONCURRENT_LLM_CALLS=2
# MAX_CACHE_SIZE_MB=256
# MAX_CONTEXT_TOKENS=8000

# Shutdown Configuration
SHUTDOWN_TIMEOUT_MS=30000

# Web Search Configuration
# Backend: auto (default) | searxng | tavily | remote | playwright | auto-browser | none
# WEB_SEARCH_BACKEND=auto

# SearXNG (lightweight, self-hosted)
# SEARXNG_BASE_URL=http://localhost:8080

# Tavily (API-based)
# TAVILY_API_KEY=your_tavily_api_key_here
# TAVILY_BASE_URL=https://api.tavily.com

# Legacy Remote API
# WEB_SEARCH_API_URL=https://your-search-api.example.com/search
# WEB_SEARCH_API_KEY=your_api_key_here

# API Auth Token (optional - when set, API requests except health/docs require Authorization: Bearer <token>)
# API_AUTH_TOKEN=

# Phase 4: Connector & Replay Configuration
CONNECTOR_MODE=mock
GENERIC_HTTP_CONNECTOR_NETWORK=disabled
REPLAY_PREVIEW_ONLY=true
