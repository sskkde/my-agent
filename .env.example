# LLM Provider Configuration
# Configure your LLM provider(s) below

# OpenRouter API Key
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DeepSeek API Key (OpenAI-compatible provider)
# Get your key at: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Domestic (China) LLM Providers ---
# Uncomment and configure the provider(s) you want to use.
# Each provider uses OpenAI-compatible API. Only one provider needs to be configured.

# DashScope (Alibaba Cloud - Qwen models)
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Volcano Engine (ByteDance - Doubao models)
# VOLCENGINE_API_KEY=your_volcengine_api_key_here
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Qianfan (Baidu - ERNIE models)
# QIANFAN_API_KEY=your_qianfan_api_key_here
# QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2

# Zhipu AI (GLM models)
# ZHIPU_API_KEY=your_zhipu_api_key_here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Moonshot AI (Kimi models)
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# MiniMax
# MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# JD Cloud Yanxi
# JDCLOUD_YANXI_API_KEY=your_jdcloud_yanxi_api_key_here
# JDCLOUD_YANXI_BASE_URL=https://api.jd.com/v1

# MiMo (Xiaomi)
# MIMO_API_KEY=your_mimo_api_key_here
# MIMO_BASE_URL=https://api.mimmo.com/v1

# iFlyTek Spark
# IFLYTEK_SPARK_API_KEY=your_iflytek_spark_api_key_here
# IFLYTEK_SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# StepFun
# STEPFUN_API_KEY=your_stepfun_api_key_here
# STEPFUN_BASE_URL=https://api.stepfun.com/v1

# Hunyuan (Tencent Cloud)
# HUNYUAN_API_KEY=your_hunyuan_api_key_here
# HUNYUAN_BASE_URL=https://hunyuan.tencentcloudapi.com/v1

# SiliconFlow (multi-model hub)
# SILICONFLOW_API_KEY=your_siliconflow_api_key_here
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Ollama Base URL (for local LLM)
# Ensure Ollama is running: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434

# MVP_USE_MOCK_LLM=true
# Set to "true" to use mock LLM adapter (deterministic routing, no real AI provider needed).
# Useful for local development / testing without configuring external LLM providers.
# Do NOT set in production.

# Application Security
# APP_SECRET_KEY - used to encrypt provider API keys at rest (generate with: openssl rand -hex 32)
APP_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
DATABASE_PATH=./data/app.db

# Port Configuration (uncomment to override defaults)
# PORT=3003
# HOST=localhost  # Set to 0.0.0.0 for production public ingress
# VITE_PORT=3002
# VITE_API_TARGET=http://localhost:3003

# Resource Limits (optional - uses defaults if not set)
# MAX_CONCURRENT_LLM_CALLS=2
# MAX_CACHE_SIZE_MB=256
# MAX_CONTEXT_TOKENS=8000

# Shutdown Configuration
SHUTDOWN_TIMEOUT_MS=30000

# Web Search Configuration
# Backend: auto (default) | searxng | tavily | remote | playwright | auto-browser | none
# WEB_SEARCH_BACKEND=auto

# SearXNG (lightweight, self-hosted)
# SEARXNG_BASE_URL=http://localhost:8080

# Tavily (API-based)
# TAVILY_API_KEY=your_tavily_api_key_here
# TAVILY_BASE_URL=https://api.tavily.com

# Legacy Remote API
# WEB_SEARCH_API_URL=https://your-search-api.example.com/search
# WEB_SEARCH_API_KEY=your_api_key_here

# API Auth Token (optional - when set, API requests except health/docs require Authorization: Bearer <token>)
# API_AUTH_TOKEN=

# Phase 4: Connector & Replay Configuration
CONNECTOR_MODE=mock
GENERIC_HTTP_CONNECTOR_NETWORK=disabled
REPLAY_PREVIEW_ONLY=true

# TOOL_LOOP_V2_ENABLED=true
# Set to "true" to enable the new tool loop implementation.
# Defaults to OFF for safety.

# File Upload Configuration
# UPLOAD_DIR=./data/uploads
# UPLOAD_MAX_FILE_SIZE_BYTES=10485760
# UPLOAD_MAX_ATTACHMENTS_PER_MESSAGE=5
# UPLOAD_ALLOWED_MIME_TYPES=text/plain,text/markdown,text/csv,application/json,image/png,image/jpeg,image/gif,image/webp,application/pdf
# UPLOAD_ALLOWED_EXTENSIONS=.txt,.md,.json,.csv,.png,.jpg,.jpeg,.gif,.webp,.pdf
# UPLOAD_PER_SESSION_QUOTA_BYTES=104857600
# UPLOAD_PREVIEW_MAX_BYTES=4096

# === Messaging Providers (optional) ===
# Configure credentials for messaging platform integrations.
# Each provider requires its own set of keys from the respective developer console.
# See docs/deployment/env-reference.md for full setup instructions.

# Feishu (飞书)
# Create an app at https://open.feishu.cn/app and enable the Bot capability.
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=         # Optional: request body encryption

# Telegram
# Create a bot via @BotFather on Telegram.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=

# DingTalk (钉钉)
# Create an internal app at https://open-dev.dingtalk.com/ and enable the Robot capability.
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=
# DINGTALK_ROBOT_CODE=
# DINGTALK_SIGN_SECRET=      # Optional: request signature verification

# QQ
# Create a bot at https://q.qq.com/ and obtain credentials.
# QQ_APP_ID=
# QQ_APP_SECRET=
# QQ_SANDBOX=false           # Optional: set to "true" for sandbox environment

# WeChat (企业微信)
# Create an app at https://work.weixin.qq.com/ and enable the Bot capability.
# WECHAT_BOT_TOKEN=
# WECHAT_APP_SECRET=
# WECHAT_APP_ID=             # Optional: for official mode
# WECHAT_ENCODING_AES_KEY=   # Optional: message encryption
# WECHAT_MODE=official       # Optional: "official" (default) or "ilink"

# AgentlyMail Connector (optional)
# Set to 'true' to enable the AgentlyMail email connector.
# Requires @tencent-qqmail/agently-cli to be installed separately.
# AGENTLY_MAIL_ENABLED=false
# AGENTLY_MAIL_CLI_PATH=agently-cli
# AGENTLY_MAIL_TIMEOUT_MS=30000
