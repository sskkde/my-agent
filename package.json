{
  "name": "agent-platform",
  "version": "0.1.0",
  "description": "Multi-agent platform for task orchestration and execution",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:api": "vitest run tests/integration/api",
    "typecheck": "tsc --noEmit",
    "start:dev": "tsx src/index.ts",
    "start:api": "tsx src/api/server.ts",
    "start:api:e2e": "DATABASE_PATH=./data/e2e.db PORT=3103 HOST=localhost tsx src/api/server.ts",
    "reset:e2e-db": "tsx scripts/reset-e2e-db.ts",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "test:web": "npm --prefix web test",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:health": "tsx src/cli/db-health.ts",
    "db:backup": "tsx src/cli/db-backup.ts",
    "install:playwright": "npx playwright install chromium"
  },
  "keywords": [
    "agent",
    "multi-agent",
    "orchestration",
    "task-management"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.9.0",
    "fastify": "^5.8.5"
  },
  "optionalDependencies": {
    "playwright": "^1.59.1"
  }
}
