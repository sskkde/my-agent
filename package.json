{
  "name": "agent-platform",
  "version": "0.8.0-ga-candidate",
  "description": "Multi-agent platform for task orchestration and execution",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --maxWorkers=1 --minWorkers=1",
    "test:e2e": "vitest run tests/e2e",
    "test:p0": "vitest run tests/e2e/full-flow-suite.test.ts --reporter=verbose",
    "test:api": "vitest run tests/integration/api",
    "test:phase4": "vitest run tests/unit/dead-letter/ tests/integration/dead-letter/ tests/integration/api/connectors-api.test.ts tests/integration/observability/ tests/architecture/workflow-trigger-connector-contract.test.ts tests/architecture/replay-preview-safety-contract.test.ts tests/e2e/flow-16-automation-beta-demo.test.ts",
    "test:p5": "tsx scripts/check-p5.ts",
    "test:p6": "tsx scripts/check-p6.ts",
    "test:p7": "tsx scripts/check-p7.ts",
    "test:p8": "tsx scripts/check-p8.ts",
    "test:p9": "npm run test:p8 && npm run test:model-input && npm run test:model-input-security && npm run test:model-input-cache && vitest run tests/unit/llm/provider-family-resolution.test.ts tests/unit/llm/deepseek-cache-usage-mapping.test.ts",
    "test:ga": "tsx scripts/check-p8.ts",
    "test:security": "vitest run tests/security",
    "test:memory-semantic-policy": "vitest run tests/unit/memory/memory-semantic-policy.test.ts",
    "test:memory-retrieval": "vitest run tests/unit/memory/hybrid-retrieval.test.ts tests/unit/memory/hybrid-retrieval-lexical-first.test.ts tests/unit/memory/entity-time-index.test.ts",
    "test:memory-lifecycle": "vitest run tests/unit/memory/lifecycle-scoring.test.ts tests/unit/memory/lifecycle-policy-rollout.test.ts",
    "test:prompt-memory": "vitest run tests/unit/kernel/model-input tests/unit/prompt tests/unit/memory",
    "test:prompt-memory-security": "vitest run tests/security/memory tests/security/model-input",
    "test:prompt-template-runtime": "vitest run tests/unit/prompt/prompt-projection-resolver.test.ts tests/unit/foreground/foreground-template-projection.test.ts",
    "test:p10": "npm run typecheck && npm run test:prompt-memory && npm run test:memory-semantic-policy && npm run test:memory-retrieval && npm run test:memory-lifecycle && npm run test:prompt-memory-security",
    "test:model-input": "vitest run tests/unit/kernel/model-input tests/integration/kernel/model-input",
    "test:model-input-security": "vitest run tests/security/model-input",
    "test:model-input-cache": "vitest run tests/unit/kernel/model-input/deepseek-cache-prefix-stability tests/unit/kernel/model-input/tool-projection-canonicalization",
    "test:tenancy": "vitest run tests/integration/tenancy/",
    "test:postgres": "vitest run tests/integration/postgres/",
    "test:prod-config": "vitest run tests/security/production-config-guard.test.ts --reporter=verbose",
    "test:performance": "RUN_PERFORMANCE_SMOKE=1 vitest run tests/performance",
    "test:load": "tsx scripts/check-load-smoke.ts",
    "test:docker": "tsx scripts/check-docker-smoke.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start:dev": "tsx src/index.ts",
    "start:api": "tsx src/api/server.ts",
    "start:api:e2e": "DATABASE_PATH=./data/e2e.db PORT=3103 HOST=localhost tsx src/api/server.ts",
    "reset:e2e-db": "tsx scripts/reset-e2e-db.ts",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "test:web": "npm --prefix web test",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:health": "tsx src/cli/db-health.ts",
    "db:backup": "tsx src/cli/db-backup.ts",
    "db:restore": "tsx scripts/check-backup-restore.ts",
    "test:backup-restore": "vitest run tests/integration/storage/backup-restore-ga.test.ts",
    "test:tool-loop": "vitest run tests/unit/tools/tool-dispatch-contract.test.ts tests/unit/tools/tool-result-message-mapper.test.ts tests/unit/kernel/tool-result-pairing-guard.test.ts tests/integration/kernel/tool-loop-closure.test.ts tests/security/tool-loop-security.test.ts",
    "test:tool-loop:e2e": "vitest run tests/e2e/flow-tool-loop-closure.test.ts",
    "test:p11-toolchain": "npm run typecheck && npm run test:tool-loop && npm run test:tool-loop:e2e && npm run test:p10 && npm run build:web",
    "install:playwright": "npm run install:cloakbrowser",
    "install:cloakbrowser": "node -e \"import('cloakbrowser').then(m => m.ensureBinary())\""
  },
  "keywords": [
    "agent",
    "multi-agent",
    "orchestration",
    "task-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "better-sqlite3": "^12.9.0",
    "fastify": "^5.8.5"
  },
  "optionalDependencies": {
    "pg": "^8.21.0",
    "cloakbrowser": "^0.3.31",
    "playwright-core": "^1.60.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
