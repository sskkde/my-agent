# Production Environment Configuration
# Copy to .env.production and fill in your values
# IMPORTANT: Never commit .env.production to version control

# =============================================================================
# SECURITY (REQUIRED)
# =============================================================================

# Application secret key for encrypting provider API keys at rest.
# Docker deployments should prefer APP_SECRET_KEY_FILE via Docker secrets.
# Generate fallback value with: openssl rand -hex 32
APP_SECRET_KEY=<generate-with-openssl-rand-hex-32>

# Optional fallback for non-Docker deployments.
# Docker deployments should prefer API_AUTH_TOKEN_FILE via Docker secrets.
# Generate with: openssl rand -hex 32
# API_AUTH_TOKEN=<generate-with-openssl-rand-hex-32>

# =============================================================================
# SERVER
# =============================================================================

HOST=0.0.0.0
PORT=3003
NODE_ENV=production

# Enable secure cookies (required for HTTPS)
COOKIE_SECURE=true

# Trust reverse proxy headers (set to 1 if behind nginx/traefik)
TRUST_PROXY=1

# =============================================================================
# DATABASE
# =============================================================================

# SQLite (default - recommended for single-node deployments)
DATABASE_PATH=/app/data/app.db

# PostgreSQL (uncomment to use - requires docker-compose.prod.yml postgres service)
# DATABASE_URL=postgresql://agentplatform@postgres:5432/agentplatform

# =============================================================================
# CORS CONFIGURATION (REQUIRED IN PRODUCTION)
# =============================================================================

# Allowed origins for CORS - MUST specify in production (no wildcard allowed)
# Multiple origins: comma-separated list
ALLOWED_ORIGINS=https://agent.nas-1.club

# =============================================================================
# PUBLIC URL
# =============================================================================

# Public base URL for OAuth redirect URIs and generated links
PUBLIC_BASE_URL=https://agent.nas-1.club

# =============================================================================
# OAUTH PROVIDERS (OPTIONAL)
# =============================================================================

# Google OAuth (uncomment and configure if using Google authentication)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# LLM PROVIDERS
# =============================================================================

# OpenRouter API key
OPENROUTER_API_KEY=

# DeepSeek API key (OpenAI-compatible provider)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Domestic (China) LLM Providers ---
# Uncomment and configure the provider(s) you want to use.
# Each provider uses OpenAI-compatible API. Only one provider needs to be configured.

# DashScope (Alibaba Cloud - Qwen models)
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Volcano Engine (ByteDance - Doubao models)
# VOLCENGINE_API_KEY=
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Qianfan (Baidu - ERNIE models)
# QIANFAN_API_KEY=
# QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2

# Zhipu AI (GLM models)
# ZHIPU_API_KEY=
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Moonshot AI (Kimi models)
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# MiniMax
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# JD Cloud Yanxi
# JDCLOUD_YANXI_API_KEY=
# JDCLOUD_YANXI_BASE_URL=https://api.jd.com/v1

# MiMo (Xiaomi)
# MIMO_API_KEY=
# MIMO_BASE_URL=https://api.mimmo.com/v1

# iFlyTek Spark
# IFLYTEK_SPARK_API_KEY=
# IFLYTEK_SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# StepFun
# STEPFUN_API_KEY=
# STEPFUN_BASE_URL=https://api.stepfun.com/v1

# Hunyuan (Tencent Cloud)
# HUNYUAN_API_KEY=
# HUNYUAN_BASE_URL=https://hunyuan.tencentcloudapi.com/v1

# SiliconFlow (multi-model hub)
# SILICONFLOW_API_KEY=
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Ollama base URL (for self-hosted LLM)
# OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# WEB SEARCH
# =============================================================================

# Backend: auto (default) | searxng | tavily | remote | playwright | auto-browser | none
WEB_SEARCH_BACKEND=auto

# SearXNG (self-hosted search; docker-compose.yml includes a searxng service)
SEARXNG_BASE_URL=http://searxng:8080

# SearXNG server secret. Override the docker-compose fallback in production.
# Generate with: openssl rand -hex 32
SEARXNG_SECRET=<generate-with-openssl-rand-hex-32>

# Tavily API
# TAVILY_API_KEY=your-tavily-api-key

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup directory path
BACKUP_DIR=/app/backups

# Number of days to retain backups
BACKUP_RETENTION_DAYS=7

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# RESOURCE LIMITS (OPTIONAL)
# =============================================================================

# Maximum concurrent LLM calls
# MAX_CONCURRENT_LLM_CALLS=2

# Maximum cache size in MB
# MAX_CACHE_SIZE_MB=256

# Maximum context tokens
# MAX_CONTEXT_TOKENS=8000

# =============================================================================
# SHUTDOWN
# =============================================================================

# Graceful shutdown timeout in milliseconds
SHUTDOWN_TIMEOUT_MS=30000

# =============================================================================
# FILE UPLOAD
# =============================================================================

# Directory for uploaded file storage (relative to cwd or absolute)
UPLOAD_DIR=/app/data/uploads

# Maximum size per file in bytes (default: 10 MiB)
# UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# Maximum attachments per message (default: 5)
# UPLOAD_MAX_ATTACHMENTS_PER_MESSAGE=5

# Allowed MIME types (comma-separated)
# UPLOAD_ALLOWED_MIME_TYPES=text/plain,text/markdown,text/csv,application/json,image/png,image/jpeg,image/gif,image/webp,application/pdf

# Allowed file extensions (comma-separated, with leading dot)
# UPLOAD_ALLOWED_EXTENSIONS=.txt,.md,.json,.csv,.png,.jpg,.jpeg,.gif,.webp,.pdf

# Per-session storage quota in bytes (default: 100 MiB)
# UPLOAD_PER_SESSION_QUOTA_BYTES=104857600

# Maximum bytes for text preview extraction (default: 4096)
# UPLOAD_PREVIEW_MAX_BYTES=4096

# =============================================================================
# CONNECTORS (OPTIONAL)
# =============================================================================

# Connector mode: mock | live
CONNECTOR_MODE=mock

# Generic HTTP connector network access
GENERIC_HTTP_CONNECTOR_NETWORK=disabled

# Replay mode (preview only for production safety)
REPLAY_PREVIEW_ONLY=true
